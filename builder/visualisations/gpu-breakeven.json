      },
      "transform": [
        {"filter": "datum.series === 'CPU fleet' || datum.series === 'GPU-' + index_type"},
        {"calculate": "datum.series === 'CPU fleet' ? 'CPU fleet' : 'GPU node'", "as": "label"}
      ],
      "mark": {"type": "line", "strokeWidth": 2.5},
      "encoding": {
        "x": {
          "field": "qps",
          "type": "quantitative",
          "scale": {"type": "log", "base": 10, "domain": [10, 100000]},
          "axis": {
            "title": "QPS",
            "values": [10, 30, 100, 300, 1000, 3000, 10000, 30000, 100000],
            "format": "~s"
          }
        },
        "y": {
          "field": "cost",
          "type": "quantitative",
          "scale": {"type": "log", "base": 10},
          "axis": {"title": "Cost per query ($)", "format": "~e"}
        },
        "color": {
          "field": "label",
          "type": "nominal",
          "scale": {
            "domain": ["CPU fleet", "GPU node"],
            "range": ["#1f6feb", "#f59e0b"]
