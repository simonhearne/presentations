{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "usermeta": {
    "embedOptions": {
      "renderer": "svg",
      "actions": false
    }
  },
  "constants_note": "CPU: AWS r6i.2xlarge $0.504/hr ~2000 QPS HNSW-768d p99<10ms. GPU: AWS g6.2xlarge $0.978/hr ~8000 QPS CAGRA-768d / ~3000 QPS HNSW-768d p99<10ms. Formula: CPU=ceil(qps/cpu_max)*cpu_rate/(qps*3600); GPU=ceil(qps/gpu_max)*gpu_rate/(qps*3600).",
  "background": "transparent",
  "width": 700,
  "height": 440,
  "config": {
    "axis": { "labelFontSize": 12, "titleFontSize": 14 },
    "legend": { "labelFontSize": 13, "titleFontSize": 13 }
  },
  "params": [
    {
      "name": "index_type",
      "value": "HNSW",
      "bind": {
        "input": "select",
        "options": ["HNSW", "CAGRA"],
        "name": "Index type: "
      }
    }
  ],
  "layer": [
    {
      "data": {
