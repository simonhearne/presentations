{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "Stepped walkthrough of product quantisation as a vertical vector column: full vector -> split into 8 sub-vectors -> nearest centroid in a codebook -> 8 centroid-ID output column. Stepped via the stage signal.",
  "width": 820,
  "height": 500,
  "padding": 5,
  "signals": [
    {"name": "stage", "value": 0},
    {"name": "colX", "value": 130},
    {"name": "outX", "value": 612},
    {"name": "stripY", "value": 100},
    {"name": "cellW", "value": 54},
    {"name": "cellH", "value": 12},
    {"name": "gap", "value": 6},
    {"name": "n", "value": 24},
    {"name": "groupH", "update": "3 * cellH + gap"},
    {"name": "s3Y", "update": "stripY + 7.5 * cellH + 2 * gap"},
    {
      "name": "headline",
      "value": "512 float32 values",
      "on": [
        {
          "events": {"signal": "stage"},
          "update": "['512 float32 values', 'split into 8 sub-vectors', 'match each slice to the codebook', 'keep 8 centroid IDs'][stage]"
        }
      ]
    },
    {
      "name": "narration",
      "value": "One 512-D vector — 2 KB of float32.",
      "on": [
        {
          "events": {"signal": "stage"},
          "update": "['One 512-D vector — 2 KB of float32.', 'Split into 8 sub-vectors of 64 dimensions each.', 'Match each sub-vector to its nearest centroid in a 256-entry codebook.', 'Keep 8 centroid IDs — 8 bytes, a 256× smaller barcode.'][stage]"
        }
      ]
    }
  ],
  "data": [
    {
      "name": "cells",
      "values": [
        {"i": 0, "v": 0.12}, {"i": 1, "v": 0.84}, {"i": 2, "v": 0.45},
        {"i": 3, "v": 0.67}, {"i": 4, "v": 0.30}, {"i": 5, "v": 0.91},
        {"i": 6, "v": 0.22}, {"i": 7, "v": 0.58}, {"i": 8, "v": 0.74},
        {"i": 9, "v": 0.15}, {"i": 10, "v": 0.63}, {"i": 11, "v": 0.40},
        {"i": 12, "v": 0.88}, {"i": 13, "v": 0.51}, {"i": 14, "v": 0.07},
        {"i": 15, "v": 0.71}, {"i": 16, "v": 0.34}, {"i": 17, "v": 0.60},
        {"i": 18, "v": 0.93}, {"i": 19, "v": 0.18}, {"i": 20, "v": 0.47},
        {"i": 21, "v": 0.80}, {"i": 22, "v": 0.25}, {"i": 23, "v": 0.55}
      ],
      "transform": [{"type": "formula", "expr": "floor(datum.i / 3)", "as": "c"}]
    },
    {
      "name": "chunks",
      "values": [
        {"c": 0, "id": 140}, {"c": 1, "id": 12}, {"c": 2, "id": 37}, {"c": 3, "id": 5},
        {"c": 4, "id": 88}, {"c": 5, "id": 201}, {"c": 6, "id": 3}, {"c": 7, "id": 219}
      ]
    },
    {
      "name": "codebook",
      "values": [
        {"cx": 360, "cy": 200}, {"cx": 420, "cy": 186}, {"cx": 482, "cy": 204}, {"cx": 512, "cy": 236},
        {"cx": 498, "cy": 290}, {"cx": 356, "cy": 276}, {"cx": 344, "cy": 334}, {"cx": 404, "cy": 342},
        {"cx": 470, "cy": 336}, {"cx": 508, "cy": 348}, {"cx": 380, "cy": 360}, {"cx": 442, "cy": 314},
        {"cx": 476, "cy": 268}, {"cx": 332, "cy": 240}
      ]
    },
    {"name": "nearest", "values": [{"cx": 414, "cy": 240, "id": 37}]},
    {"name": "query", "values": [{"qx": 346, "qy": 214}]}
  ],
  "scales": [
    {
      "name": "heat",
      "type": "linear",
      "domain": [0, 1],
      "range": ["#e6f0ff", "#49bcff", "#175fff", "#061982"]
    }
  ],
  "marks": [
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"signal": "(colX + outX + cellW) / 2"},
          "y": {"value": 50},
          "text": {"signal": "headline"},
          "align": {"value": "center"}, "baseline": {"value": "alphabetic"},
          "fontSize": {"value": 21}, "fontWeight": {"value": "bold"},
          "fill": {"value": "#1e293b"}
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"signal": "colX + cellW / 2"},
          "y": {"signal": "stripY - 12"},
          "text": {"value": "the vector · 512-D"},
          "align": {"value": "center"}, "baseline": {"value": "alphabetic"},
          "fontSize": {"value": 13}, "fontWeight": {"value": "bold"},
          "fill": {"value": "#64748b"}
        }
      }
    },
    {
      "type": "rect",
      "from": {"data": "cells"},
      "encode": {
        "update": {
          "x": {"signal": "colX"},
          "width": {"signal": "cellW"},
          "y": {"signal": "stripY + datum.i * cellH + (stage >= 1 ? datum.c * gap : 0)"},
          "height": {"signal": "cellH - 1.5"},
          "fill": {"scale": "heat", "field": "v"},
          "cornerRadius": {"value": 1.5}
        }
      }
    },
    {
      "type": "rect",
      "from": {"data": "chunks"},
      "encode": {
        "update": {
          "x": {"signal": "colX - 2.5"},
          "width": {"signal": "cellW + 5"},
          "y": {"signal": "stripY + datum.c * 3 * cellH + datum.c * gap - 1.5"},
          "height": {"signal": "3 * cellH - 1.5 + 3"},
          "fill": {"value": "transparent"},
          "cornerRadius": {"value": 3},
          "stroke": {"value": "#9d41ff"},
          "strokeWidth": {"value": 2},
          "opacity": [{"test": "stage === 2 && datum.c === 2", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "chunks"},
      "encode": {
        "update": {
          "x": {"signal": "colX - 14"},
          "y": {"signal": "stripY + (datum.c * 3 + 1.5) * cellH + datum.c * gap"},
          "text": {"signal": "'s' + (datum.c + 1)"},
          "align": {"value": "right"}, "baseline": {"value": "middle"},
          "fontSize": {"value": 12},
          "fontWeight": [{"test": "stage === 2 && datum.c === 2", "value": "bold"}, {"value": "normal"}],
          "fill": [{"test": "stage === 2 && datum.c === 2", "value": "#9d41ff"}, {"value": "#94a3b8"}],
          "opacity": [{"test": "stage === 1 || stage === 2", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "rect",
      "encode": {
        "update": {
          "x": {"value": 312}, "x2": {"value": 548},
          "y": {"value": 158}, "y2": {"value": 384},
          "fill": {"value": "#f8fafc"},
          "fillOpacity": {"value": 0.7},
          "stroke": {"value": "#cbd5e1"},
          "strokeWidth": {"value": 1},
          "cornerRadius": {"value": 8},
          "opacity": [{"test": "stage === 2", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"value": 430}, "y": {"value": 150},
          "text": {"value": "256-entry codebook"},
          "align": {"value": "center"}, "baseline": {"value": "alphabetic"},
          "fontSize": {"value": 13}, "fontWeight": {"value": "bold"},
          "fill": {"value": "#1e293b"},
          "opacity": [{"test": "stage === 2", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "symbol",
      "from": {"data": "codebook"},
      "encode": {
        "update": {
          "x": {"field": "cx"}, "y": {"field": "cy"},
          "shape": {"value": "circle"}, "size": {"value": 90},
          "fill": {"value": "#cbd5e1"},
          "stroke": {"value": "#94a3b8"}, "strokeWidth": {"value": 1},
          "opacity": [{"test": "stage === 2", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "rule",
      "from": {"data": "query"},
      "encode": {
        "update": {
          "x": {"signal": "colX + cellW + 4"}, "y": {"signal": "s3Y"},
          "x2": {"field": "qx"}, "y2": {"field": "qy"},
          "stroke": {"value": "#9d41ff"}, "strokeWidth": {"value": 1.5},
          "strokeDash": {"value": [4, 3]},
          "opacity": [{"test": "stage === 2", "value": 0.8}, {"value": 0}]
        }
      }
    },
    {
      "type": "rule",
      "from": {"data": "query"},
      "encode": {
        "update": {
          "x": {"field": "qx"}, "y": {"field": "qy"},
          "x2": {"value": 414}, "y2": {"value": 240},
          "stroke": {"value": "#9d41ff"}, "strokeWidth": {"value": 1.5},
          "opacity": [{"test": "stage === 2", "value": 0.9}, {"value": 0}]
        }
      }
    },
    {
      "type": "symbol",
      "from": {"data": "query"},
      "encode": {
        "update": {
          "x": {"field": "qx"}, "y": {"field": "qy"},
          "shape": {"value": "diamond"}, "size": {"value": 170},
          "fill": {"value": "#ff5757"},
          "stroke": {"value": "#7f1d1d"}, "strokeWidth": {"value": 1.5},
          "opacity": [{"test": "stage === 2", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "symbol",
      "from": {"data": "nearest"},
      "encode": {
        "update": {
          "x": {"field": "cx"}, "y": {"field": "cy"},
          "shape": {"value": "circle"}, "size": {"value": 320},
          "fill": {"value": "#9d41ff"},
          "stroke": {"value": "#5f1f9c"}, "strokeWidth": {"value": 2},
          "opacity": [{"test": "stage === 2", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "nearest"},
      "encode": {
        "update": {
          "x": {"signal": "datum.cx + 16"}, "y": {"field": "cy"},
          "text": {"signal": "'centroid #' + datum.id"},
          "align": {"value": "left"}, "baseline": {"value": "middle"},
          "fontSize": {"value": 12}, "fontWeight": {"value": "bold"},
          "fill": {"value": "#5f1f9c"},
          "opacity": [{"test": "stage === 2", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "rule",
      "encode": {
        "update": {
          "x": {"signal": "colX + cellW + 30"}, "x2": {"signal": "outX - 28"},
          "y": {"signal": "stripY + 12 * cellH + 4 * gap"}, "y2": {"signal": "stripY + 12 * cellH + 4 * gap"},
          "stroke": {"value": "#94a3b8"}, "strokeWidth": {"value": 2},
          "opacity": [{"test": "stage >= 3", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "symbol",
      "encode": {
        "update": {
          "x": {"signal": "outX - 28"}, "y": {"signal": "stripY + 12 * cellH + 4 * gap"},
          "shape": {"value": "triangle-right"}, "size": {"value": 110},
          "fill": {"value": "#94a3b8"},
          "opacity": [{"test": "stage >= 3", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"signal": "outX + cellW / 2"},
          "y": {"signal": "stripY - 12"},
          "text": {"value": "8 centroid IDs"},
          "align": {"value": "center"}, "baseline": {"value": "alphabetic"},
          "fontSize": {"value": 13}, "fontWeight": {"value": "bold"},
          "fill": {"value": "#175fff"},
          "opacity": [{"test": "stage >= 3", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "rect",
      "from": {"data": "chunks"},
      "encode": {
        "update": {
          "x": {"signal": "outX"},
          "width": {"signal": "cellW"},
          "y": {"signal": "stripY + datum.c * 3 * cellH + datum.c * gap"},
          "height": {"signal": "3 * cellH - 1.5"},
          "fill": {"value": "#175fff"},
          "cornerRadius": {"value": 3},
          "opacity": [{"test": "stage >= 3", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "chunks"},
      "encode": {
        "update": {
          "x": {"signal": "outX + cellW / 2"},
          "y": {"signal": "stripY + (datum.c * 3 + 1.5) * cellH + datum.c * gap"},
          "text": {"signal": "datum.id"},
          "align": {"value": "center"}, "baseline": {"value": "middle"},
          "fontSize": {"value": 14}, "fontWeight": {"value": "bold"},
          "fill": {"value": "#ffffff"},
          "opacity": [{"test": "stage >= 3", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"signal": "(colX + outX + cellW) / 2"},
          "y": {"value": 82},
          "text": {"value": "2 KB  →  8 bytes   ·   256× smaller"},
          "align": {"value": "center"}, "baseline": {"value": "alphabetic"},
          "fontSize": {"value": 18}, "fontWeight": {"value": "bold"},
          "fill": {"value": "#175fff"},
          "opacity": [{"test": "stage >= 3", "value": 1}, {"value": 0}]
        }
      }
    },
    {
      "type": "text",
      "encode": {
        "update": {
          "x": {"signal": "(colX + outX + cellW) / 2"},
          "y": {"value": 476},
          "text": {"signal": "narration"},
          "align": {"value": "center"}, "baseline": {"value": "alphabetic"},
          "fontSize": {"value": 16}, "fill": {"value": "#1e293b"}
        }
      }
    }
  ]
}
